    {
      "id": "node_hello",
      "type": "normal",
      "npc": { "text": "Hello, come in and sit down. What is wrong today?", "gender": "male" },
      "context": { "scene": "healthy", "situation": "The doctor greets the patient." },
      "learning_objective": ["Say how you feel", "Describe a problem"],
      "routes": [
        {
          "intent": "describe_symptom",
          "meaning": "The patient says they feel sick or something hurts.",
          "examples": ["I feel sick.", "I have a headache.", "My tummy hurts.", "I don't feel well.", "I have a cough.", "I feel bad today."],
          "keywords": ["sick", "hurt", "hurts", "headache", "cough", "cold", "fever", "pain", "well", "bad"],
          "objective": { "label": "Describe how you feel", "markers": ["i feel", "i have", "my", "hurts", "sick", "don't feel well"] },
          "next_nodes": [
            { "id": "node_where", "weight": 70 },
            { "id": "node_since_when", "weight": 30 }
          ]
        }
      ],
      "fallback": {
        "partial": { "stay_on_current_node": true, "message": "Tell me the problem. You can say 'I feel sick.'" },
        "off_topic": { "stay_on_current_node": true, "message": "I am the doctor. How do you feel today?" }
      }
    },

    {
      "id": "node_where",
      "type": "normal",
      "npc": { "text": "I'm sorry to hear that. Where does it hurt?", "gender": "male" },
      "context": { "scene": "healthy", "situation": "The doctor asks where the pain is." },
      "learning_objective": ["Name body parts", "Say where it hurts"],
      "routes": [
        {
          "intent": "say_body_part",
          "meaning": "The patient names the body part that hurts.",
          "examples": ["My head hurts.", "My stomach.", "It's my throat.", "My tooth hurts.", "My leg.", "Here, my ear."],
          "keywords": ["head", "stomach", "tummy", "throat", "tooth", "leg", "arm", "ear", "back", "hand", "foot"],
          "objective": { "label": "Name a body part", "markers": ["head", "stomach", "tummy", "throat", "tooth", "leg", "arm", "ear", "back", "hand", "foot", "my"] },
          "next_nodes": [{ "id": "node_check", "weight": 100 }]
        }
      ],
      "fallback": {
        "partial": { "stay_on_current_node": true, "message": "Say where it hurts. You can say 'My head hurts.'" },
        "off_topic": { "stay_on_current_node": true, "message": "Where does it hurt? Point and tell me." }
      }
    },

    {
      "id": "node_since_when",
      "type": "event",
      "npc": { "text": "Okay. Since when have you felt like this? Since today or yesterday?", "gender": "male" },
      "context": { "scene": "healthy", "situation": "The doctor asks how long the patient has been sick." },
      "learning_objective": ["Talk about time (today, yesterday)"],
      "routes": [
        {
          "intent": "say_time",
          "meaning": "The patient says when it started.",
          "examples": ["Since yesterday.", "Since this morning.", "Two days ago.", "Since today."],
          "keywords": ["yesterday", "today", "morning", "days", "ago", "since", "night"],
          "next_nodes": [{ "id": "node_where", "weight": 100 }]
        }
      ],
      "fallback": {
        "partial": { "stay_on_current_node": true, "message": "Say when it started. You can say 'Since yesterday.'" },
        "off_topic": { "stay_on_current_node": true, "message": "When did it start — today or yesterday?" }
      }
    },

    {
      "id": "node_check",
      "type": "normal",
      "npc": { "text": "Let me check. Open your mouth, please... Do you have a fever?", "gender": "male" },
      "context": { "scene": "healthy", "situation": "The doctor examines the patient." },
      "learning_objective": ["Answer yes/no questions", "Talk about symptoms"],
      "routes": [
        {
          "intent": "affirm",
          "meaning": "The patient has a fever.",
          "examples": ["Yes, I think so.", "Yes, I feel hot.", "Yes, a little.", "Yes."],
          "keywords": ["yes", "hot", "warm", "little"],
          "next_nodes": [{ "id": "node_advice_fever", "weight": 100 }]
        },
        {
          "intent": "decline",
          "meaning": "The patient does not have a fever.",
          "examples": ["No, I don't think so.", "No fever.", "No.", "I don't feel hot."],
          "keywords": ["no", "not", "fever", "cold"],
          "next_nodes": [{ "id": "node_advice_rest", "weight": 100 }]
        }
      ],
      "fallback": {
        "partial": { "stay_on_current_node": true, "message": "Do you feel hot? Say 'Yes' or 'No.'" },
        "off_topic": { "stay_on_current_node": true, "message": "Do you have a fever? Yes or no?" }
      }
    },

    {
