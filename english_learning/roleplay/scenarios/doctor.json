          "next_nodes": [{ "id": "node_medicine", "weight": 100 }]
        },
        {
          "intent": "ask_question",
          "meaning": "The patient asks a follow-up question.",
          "examples": ["Can I go to school?", "How long will it take?", "Can I play outside?", "What can I eat?"],
          "keywords": ["can", "how", "long", "school", "play", "eat"],
          "next_nodes": [{ "id": "node_advice_rest", "weight": 100 }]
        }
      ],
      "fallback": {
        "partial": { "stay_on_current_node": true, "message": "Say 'Okay, I will.' or ask a question." },
        "off_topic": { "stay_on_current_node": true, "message": "You should rest and drink water. Is that okay?" }
      }
    },

    {
      "id": "node_advice_rest",
      "type": "normal",
      "npc": { "text": "Good. You just need some rest. And remember to wash your hands often, okay?", "gender": "male" },
      "context": { "scene": "healthy", "situation": "The doctor gives healthy-habit advice." },
      "learning_objective": ["Understand healthy habits", "Agree"],
      "routes": [
        {
          "intent": "affirm",
          "meaning": "The patient agrees.",
          "examples": ["Okay, I will.", "Yes, I understand.", "Sure, I'll wash my hands.", "Okay, doctor."],
          "keywords": ["okay", "yes", "will", "wash", "understand"],
          "next_nodes": [{ "id": "node_medicine", "weight": 100 }]
        }
