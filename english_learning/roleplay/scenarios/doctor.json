      "fallback": {
        "partial": { "stay_on_current_node": true, "message": "Say 'Okay, I will.'" },
        "off_topic": { "stay_on_current_node": true, "message": "Please rest and wash your hands, okay?" }
      }
    },

    {
      "id": "node_medicine",
      "type": "event",
      "npc": { "text": "Here is some medicine. Take it two times a day, after food. Do you understand?", "gender": "male" },
      "context": { "scene": "healthy", "situation": "The doctor explains the medicine." },
      "learning_objective": ["Understand instructions", "Ask to repeat"],
      "routes": [
        {
          "intent": "affirm",
          "meaning": "The patient understands the instructions.",
          "examples": ["Yes, I understand.", "Okay, two times a day.", "Yes, thank you.", "Got it."],
          "keywords": ["yes", "understand", "okay", "got", "times"],
          "next_nodes": [{ "id": "node_bye", "weight": 100 }]
        },
        {
          "intent": "ask_repeat",
          "meaning": "The patient asks the doctor to repeat.",
          "examples": ["Can you say it again?", "Sorry, one more time?", "How many times?", "I don't understand."],
          "keywords": ["again", "repeat", "sorry", "many", "understand"],
          "next_nodes": [{ "id": "node_repeat", "weight": 100 }]
        }
